{
  "name": "editify",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first PDF desktop app foundation",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "test": "python -m unittest discover -s python/tests -p \"test_*.py\"",
    "test:verify-assets": "node scripts/verify-05-dev-assets.mjs",
    "lint": "eslint e2e scripts node-tests src/main src/renderer/mani-color-picker.js src/renderer/floating-panel-drag.js src/renderer/renderer-text-html.js src/renderer/renderer-text-ctx.js src/renderer/renderer-utils.js src/renderer/renderer-toast.js src/renderer/renderer-sidebars.js src/renderer/renderer-text-ctx-menu.js src/renderer/renderer-shape-image-ctx-menu.js src/renderer/renderer-split-workspace.js",
    "format": "prettier --write \"e2e/**/*.js\" \"node-tests/**/*.js\" \"scripts/**/*.mjs\" \"src/main/**/*.js\" \"src/renderer/mani-color-picker.js\" \"src/renderer/floating-panel-drag.js\" \"src/renderer/renderer-text-html.js\" \"src/renderer/renderer-text-ctx.js\" \"src/renderer/renderer-utils.js\" \"src/renderer/renderer-toast.js\" \"src/renderer/renderer-sidebars.js\" \"src/renderer/renderer-text-ctx-menu.js\" \"src/renderer/renderer-shape-image-ctx-menu.js\" \"src/renderer/renderer-split-workspace.js\" \"eslint.config.mjs\"",
    "format:check": "prettier --check \"e2e/**/*.js\" \"node-tests/**/*.js\" \"scripts/**/*.mjs\" \"src/main/**/*.js\" \"src/renderer/mani-color-picker.js\" \"src/renderer/floating-panel-drag.js\" \"src/renderer/renderer-text-html.js\" \"src/renderer/renderer-text-ctx.js\" \"src/renderer/renderer-utils.js\" \"src/renderer/renderer-toast.js\" \"src/renderer/renderer-sidebars.js\" \"src/renderer/renderer-text-ctx-menu.js\" \"src/renderer/renderer-shape-image-ctx-menu.js\" \"src/renderer/renderer-split-workspace.js\" \"eslint.config.mjs\"",
    "test:spell": "node scripts/spellcheck-smoke.mjs",
    "test:node": "node --test \"node-tests/**/*.test.js\"",
    "test:coverage": "c8 node --test \"node-tests/**/*.test.js\"",
    "test:audit": "npm audit --audit-level=high",
    "e2e": "playwright test",
    "test:all": "npm run test:verify-assets && npm run format:check && npm run lint && npm run test:coverage && npm run test:audit && npm test && npm run test:spell && npm run e2e",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "c8": {
    "all": true,
    "include": ["src/main/**/*.js"],
    "exclude": ["src/main/main.js", "src/main/preload.js", "src/main/logger.js"],
    "reporter": ["text", "html"],
    "reports-dir": "coverage",
    "check-coverage": true,
    "lines": 80,
    "functions": 80,
    "branches": 75,
    "statements": 80
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "c8": "^10.1.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.5.3"
  },
  "build": {
    "appId": "com.manipdf.local",
    "productName": "Editify",
    "files": [
      "src/**/*",
      "python/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "dictionary-en": "^4.0.0",
    "dictionary-es": "^4.0.0",
    "dictionary-fr": "^3.0.0",
    "dictionary-pt-br": "^3.0.0",
    "nspell": "^2.1.5",
    "pdfjs-dist": "^5.6.205"
  }
}
